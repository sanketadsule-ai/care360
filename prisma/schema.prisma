generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model users {
  id         String     @id @default(uuid()) @db.VarChar(36)
  email      String     @unique @db.VarChar(255)
  name       String     @db.VarChar(255)
  avatar_url String?    @db.VarChar(512)
  role       String     @default("agent")
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt
  channels   channels[]
  messages   messages[]
  settings   settings[]
}

model channels {
  id               String     @id @default(uuid()) @db.VarChar(36)
  user_id          String     @db.VarChar(36)
  platform         String
  platform_id      String     @db.VarChar(255)
  name             String     @db.VarChar(255)
  handle           String?    @db.VarChar(255)
  avatar_url       String?    @db.VarChar(512)
  access_token     String     @db.Text
  token_expires_at DateTime?
  is_admin         Boolean    @default(true)
  status           String     @default("active")
  connected_at     DateTime   @default(now())
  updated_at       DateTime   @updatedAt
  user             users      @relation(fields: [user_id], references: [id])
  messages         messages[]
}

model messages {
  id                  String   @id @default(uuid()) @db.VarChar(36)
  channel_id          String   @db.VarChar(36)
  platform_message_id String   @unique @db.VarChar(255)
  type                String
  author_name         String   @db.VarChar(255)
  author_handle       String?  @db.VarChar(255)
  author_avatar_url   String?  @db.VarChar(512)
  content             String   @db.Text
  sentiment           String   @default("unset")
  status              String   @default("open")
  assigned_to         String?  @db.VarChar(36)
  source_url          String?  @db.VarChar(1024)
  platform_created_at DateTime
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  channel             channels @relation(fields: [channel_id], references: [id])
  assignee            users?   @relation(fields: [assigned_to], references: [id])
}

model settings {
  id         String   @id @default(uuid()) @db.VarChar(36)
  user_id    String   @db.VarChar(36)
  key        String   @db.VarChar(255)
  value      Json
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user       users    @relation(fields: [user_id], references: [id])

  @@unique([user_id, key])
}

model trustpilot_reviews {
  id          String   @id @default(uuid()) @db.VarChar(36)
  review_id   String   @unique @db.VarChar(255)
  author_name String   @db.VarChar(255)
  rating      String   @db.VarChar(10)
  heading     String   @db.Text
  body        String   @db.Text
  date        String   @db.VarChar(255)
  created_at  DateTime @default(now())
}
